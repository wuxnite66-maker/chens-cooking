# ── Reservation email delivery (Resend) ───────────────────────────────
# Sign up free at https://resend.com → API Keys → create one.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that should RECEIVE reservations (the restaurant's email).
RESERVATION_TO=reservierung@chens-cooking.at

# Sender address. For quick testing use Resend's shared sender below
# (it can only deliver to the email you signed up with).
# For production, verify your domain in Resend and use e.g.
#   "Chen's Cooking <reservierung@chens-cooking.at>"
RESERVATION_FROM=Chen's Cooking <onboarding@resend.dev>

# ── Google Calendar auto-entry (optional) ─────────────────────────────
# When set, every reservation is also written to a Google Calendar.
# Setup: Google Cloud → enable "Google Calendar API" → create a service
# account + JSON key → share your calendar with the service-account email
# ("Make changes to events") → copy the values below. See DEPLOY.md.
GOOGLE_CLIENT_EMAIL=chens-reservations@your-project.iam.gserviceaccount.com
# Paste the whole private key. Keep the \n or paste real line breaks.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Calendar ID (Calendar settings → "Integrate calendar"). Often your gmail
# address, or a …@group.calendar.google.com id.
GOOGLE_CALENDAR_ID=your-email@gmail.com
# Optional:
GOOGLE_CALENDAR_TZ=Europe/Budapest
RESERVATION_DURATION_MIN=120
