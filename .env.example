# ── Reservation email delivery (Resend) ───────────────────────────────
# Sign up free at https://resend.com → API Keys → create one.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that should RECEIVE reservations (the restaurant's email).
RESERVATION_TO=reservierung@chens-cooking.at

# Sender address. For quick testing use Resend's shared sender below
# (it can only deliver to the email you signed up with).
# For production, verify your domain in Resend and use e.g.
#   "Chen's Cooking <reservierung@chens-cooking.at>"
RESERVATION_FROM=Chen's Cooking <onboarding@resend.dev>

# ── Google Calendar auto-entry (optional) ─────────────────────────────
# When set, every reservation is also written into your Google Calendar.
# No API keys / Google Cloud needed — it uses a Google Apps Script that
# runs under your own Google account. Setup guide + code:
#   scripts/google-calendar-webhook.gs  (see GOOGLE_CALENDAR_ANLEITUNG.md)
# Paste the deployed Web-App URL (ends with /exec) here:
# GOOGLE_CALENDAR_WEBHOOK=https://script.google.com/macros/s/DEINE_ID/exec

# ── VintFlow · KI-Assistent für Vinted-Inserate (/vinted) ─────────────
# Die App läuft komplett OHNE Konfiguration: Ohne Key erzeugt sie Titel,
# Beschreibung, Tags und Preis aus einer regelbasierten Vorlage.
# Ist ein Anthropic-Key gesetzt, schreibt Claude die Texte (und wertet
# optional das Produktfoto mit aus).
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Optionales Modell-Override (Standard: claude-haiku-4-5-20251001):
# VINTED_AI_MODEL=claude-haiku-4-5-20251001
